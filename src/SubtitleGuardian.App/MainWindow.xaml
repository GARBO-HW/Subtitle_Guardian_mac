<Window x:Class="SubtitleGuardian.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SubtitleGuardian.App"
        mc:Ignorable="d"
        Title="字幕御守" Height="800" Width="1024"
    Icon="pack://application:,,,/Assets/SubtitleGuardianIcon.ico">
    <DockPanel Margin="16">
        <Grid DockPanel.Dock="Bottom" Height="200" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressBar x:Name="SelectedJobProgress" Height="18" Minimum="0" Maximum="100" />
                <Button x:Name="CancelSelectedTaskButton" Grid.Column="1" Content="取消選取任務" Width="140" Height="28" Margin="12,0,0,0" Click="OnCancelSelectedTask" Visibility="Collapsed" />
            </Grid>

            <ListView x:Name="JobsList" Grid.Row="1" SelectionChanged="OnJobSelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="任務" DisplayMemberBinding="{Binding Title}" Width="200" />
                        <GridViewColumn Header="狀態" DisplayMemberBinding="{Binding Status}" Width="70" />
                        <GridViewColumn Header="進度" DisplayMemberBinding="{Binding Percent}" Width="40" />
                        <GridViewColumn Header="開始" DisplayMemberBinding="{Binding StartTime}" Width="70" />
                        <GridViewColumn Header="結束" DisplayMemberBinding="{Binding EndTime}" Width="70" />
                        <GridViewColumn Header="耗時" DisplayMemberBinding="{Binding Duration}" Width="70" />
                        <GridViewColumn Header="訊息" DisplayMemberBinding="{Binding Message}" Width="250" />
                        <GridViewColumn Header="錯誤" DisplayMemberBinding="{Binding ErrorMessage}" Width="150" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <TabControl x:Name="MainTabs">
        </TabControl>
    </DockPanel>
</Window>
