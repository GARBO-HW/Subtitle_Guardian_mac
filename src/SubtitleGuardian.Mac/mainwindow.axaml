<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SubtitleGuardian.Mac"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="800"
        x:Class="SubtitleGuardian.Mac.MainWindow"
        Title="Subtitle Guardian (Mac)" Width="1024" Height="800"
        Icon="/Assets/SubtitleGuardianIcon.ico">
    <DockPanel Margin="16">
        <Grid DockPanel.Dock="Bottom" Height="200" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressBar x:Name="SelectedJobProgress" Height="18" Minimum="0" Maximum="100" />
                <Button x:Name="CancelSelectedTaskButton" Grid.Column="1" Content="取消選取任務" Width="140" Height="28" Margin="12,0,0,0" Click="OnCancelSelectedTask" IsVisible="False" />
            </Grid>

            <DataGrid x:Name="JobsList" Grid.Row="1" SelectionChanged="OnJobSelectionChanged" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="任務" Binding="{Binding Title}" Width="200" />
                    <DataGridTextColumn Header="狀態" Binding="{Binding Status}" Width="70" />
                    <DataGridTextColumn Header="進度" Binding="{Binding Percent}" Width="40" />
                    <DataGridTextColumn Header="開始" Binding="{Binding StartTime}" Width="70" />
                    <DataGridTextColumn Header="結束" Binding="{Binding EndTime}" Width="70" />
                    <DataGridTextColumn Header="耗時" Binding="{Binding Duration}" Width="70" />
                    <DataGridTextColumn Header="訊息" Binding="{Binding Message}" Width="250" />
                    <DataGridTextColumn Header="錯誤" Binding="{Binding ErrorMessage}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <TabControl x:Name="MainTabs">
        </TabControl>
    </DockPanel>
</Window>
