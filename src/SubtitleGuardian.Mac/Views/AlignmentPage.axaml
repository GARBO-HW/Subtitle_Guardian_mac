<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SubtitleGuardian.Mac.Views.AlignmentPage"
             DragDrop.AllowDrop="True">
    
    <ScrollViewer>
        <StackPanel Margin="10" Spacing="15">
            <!-- 1. Audio Source -->
            <StackPanel Spacing="5">
                <TextBlock Text="1. 選擇音訊/影片來源" FontWeight="Bold" />
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="AudioSourceText" Height="28" IsReadOnly="True" Margin="0,0,8,0" 
                             DragDrop.AllowDrop="True" />
                    <Button x:Name="PickAudioButton" Content="選擇檔案" Grid.Column="1" Width="100" Height="28" Click="OnPickAudio" />
                </Grid>
            </StackPanel>

            <!-- 2. Text Source -->
            <StackPanel Spacing="5">
                <TextBlock Text="2. 輸入正確文稿" FontWeight="Bold" />
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,5">
                    <TextBlock Text="文稿來源：" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBox x:Name="TextSourcePathText" Grid.Column="1" Height="28" IsReadOnly="True" Margin="0,0,8,0" 
                             DragDrop.AllowDrop="True" />
                    <Button x:Name="PickTextButton" Content="匯入文字檔" Grid.Column="2" Width="100" Height="28" Click="OnPickTextFile" />
                </Grid>
                
                <TextBlock Text="或直接貼上文字內容：" />
                <TextBox x:Name="TranscriptInput" MinHeight="100" AcceptsReturn="True" TextWrapping="Wrap" /> 
            </StackPanel>

            <!-- 3. Alignment Settings -->
            <StackPanel Spacing="5">
                <TextBlock Text="3. 設定" FontWeight="Bold" />
                <Grid ColumnDefinitions="Auto,Auto,20,Auto,Auto">
                    <TextBlock Text="語言：" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <ComboBox x:Name="LanguageCombo" Grid.Column="1" Width="140" Height="28" 
                              DisplayMemberBinding="{Binding Label}" SelectedValueBinding="{Binding Code}" />
                    
                    <TextBlock Text="最大單行字數：" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBox x:Name="MaxCharsText" Grid.Column="4" Width="60" Height="28" Text="40" 
                             HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                </Grid>
            </StackPanel>

            <!-- 4. Action -->
            <StackPanel Spacing="5">
                <TextBlock Text="4. 輸出與執行" FontWeight="Bold" />
                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <TextBlock Text="輸出目錄：" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBox x:Name="ExportDirText" Grid.Column="1" Height="28" Margin="0,0,5,0" />
                    <Button x:Name="BrowseExportButton" Content="..." Grid.Column="2" Width="40" Height="28" Margin="0,0,10,0" Click="OnBrowseExport" />
                    
                    <Button x:Name="AlignButton" Grid.Column="3" Content="開始匹配 (Align)" Width="160" Height="36" 
                            Click="OnStartAlignment" IsEnabled="False" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
